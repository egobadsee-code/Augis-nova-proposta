<script>
const secs=document.querySelectorAll('section'),dots=document.querySelectorAll('.dot');
function goto(i){secs[i].scrollIntoView({behavior:'smooth'});}
const obs=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting){const i=Array.from(secs).indexOf(x.target);dots.forEach((d,j)=>d.classList.toggle('active',i===j));}});},{threshold:.5});
secs.forEach(s=>obs.observe(s));
